<Window x:Class="MemoryGame.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:MemoryGame.Client.Localization"
        mc:Ignorable="d"
        Title="Memory Game"
        Height="720" Width="1280"
        MinHeight="720" MinWidth="980"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="Resources/Images/logo-en.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="46" CornerRadius="24" GlassFrameThickness="0" ResizeBorderThickness="8"/>
    </WindowChrome.WindowChrome>

    <!-- F11: toggle fullscreen -->
    <Window.InputBindings>
        <KeyBinding Key="F11" Command="{Binding ToggleFullscreenCommand}"/>
    </Window.InputBindings>

    <Border x:Name="MainWindowBorder" Background="{DynamicResource PastelBackground}" CornerRadius="14" ClipToBounds="True">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" Value="Maximized">
                        <Setter Property="CornerRadius" Value="0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <!-- Traffic Light MacOS buttons (Top-Left) -->
            <StackPanel x:Name="TrafficLights" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="18,18,0,0" Panel.ZIndex="100"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Width="14" Height="14" Background="#FF5F56" BorderThickness="0" Cursor="Hand" Margin="0,0,8,0" Click="OnMacCloseClicked" ToolTip="Cerrar">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="7">
                                <TextBlock x:Name="Icon" Text="×" FontSize="10" Foreground="#44000000" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Hidden" Margin="0,0,0,1"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=StackPanel}}" Value="True">
                                    <Setter TargetName="Icon" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#E04E45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="14" Height="14" Background="#FFBD2E" BorderThickness="0" Cursor="Hand" Margin="0,0,8,0" Click="OnMacMinimizeClicked" ToolTip="Minimizar">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="7">
                                <TextBlock x:Name="Icon" Text="–" FontSize="10" Foreground="#44000000" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Hidden" Margin="0,1,0,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=StackPanel}}" Value="True">
                                    <Setter TargetName="Icon" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#E6A925"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="14" Height="14" Background="#27C93F" BorderThickness="0" Cursor="Hand" Click="OnMacMaximizeClicked" ToolTip="Maximizar">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="7">
                                <TextBlock x:Name="Icon" Text="+" FontSize="9" Foreground="#44000000" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Hidden"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=StackPanel}}" Value="True">
                                    <Setter TargetName="Icon" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#1FB335"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- Active view (fills the entire window) — content is swapped in code-behind with a fade transition -->
        <ContentControl x:Name="PageContent"/>

        <!-- Global header Menu — Aligned with back buttons (Row 1 of views) -->
        <Grid HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,52,18,0"
              WindowChrome.IsHitTestVisibleInChrome="True">
            <ToggleButton x:Name="MenuToggleBtn"
                          Width="56" Height="56" Cursor="Hand" ToolTip="Menu"
                          Background="Transparent" BorderThickness="0">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root" Background="Transparent" CornerRadius="28" Width="56" Height="56">
                            <Image Source="{DynamicResource MenuIconSource}"
                                   Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Background" Value="#22000000"/></Trigger>
                            <Trigger Property="IsChecked" Value="True"><Setter TargetName="Root" Property="Background" Value="#44000000"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </ToggleButton.Template>
            </ToggleButton>

            <!-- Dropdown Popup -->
            <Popup IsOpen="{Binding IsChecked, ElementName=MenuToggleBtn, Mode=TwoWay}"
                   PlacementTarget="{Binding ElementName=MenuToggleBtn}"
                   Placement="Bottom" HorizontalOffset="-104" VerticalOffset="8"
                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="{DynamicResource CardCornerRadius}"
                        Padding="24,20"
                        DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=Popup}}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.14" Color="#3D1C1C"/>
                    </Border.Effect>
                    <StackPanel Width="160">
                        <!-- Profile / Friends / Register -->
                        <Button Style="{DynamicResource PastelDropdownButton}" Command="{Binding GoToProfileCommand}" Margin="0,0,0,4" Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[MainMenu_Button_Profile], FallbackValue=Profile}"/>
                        <Button Style="{DynamicResource PastelDropdownButton}" Command="{Binding GoToFriendsCommand}" Margin="0,0,0,4" Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[MainMenu_Button_Friends], FallbackValue=Friends}"/>
                        <Button Style="{DynamicResource PastelDropdownButton}" Command="{Binding GoToGuestRegisterCommand}" Margin="0,0,0,4" Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Register], FallbackValue=Register}" Visibility="{Binding GuestRegisterVisibility}"/>
                        
                        <!-- Settings -->
                        <Rectangle Style="{DynamicResource SectionDivider}" Margin="8,4,8,8" Height="1"/>
                        <Button Style="{DynamicResource PastelDropdownButton}" Command="{Binding GoToSettingsCommand}" Margin="0,0,0,0" Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[MainMenu_Button_Settings], FallbackValue=Settings}"/>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
        </Grid>
    </Border>
</Window>
