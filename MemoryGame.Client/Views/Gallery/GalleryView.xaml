<UserControl x:Class="MemoryGame.Client.Views.Gallery.GalleryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MemoryGame.Client.Localization"
             xmlns:behaviors="clr-namespace:MemoryGame.Client.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720">

    <Grid>
        <!-- Background -->
        <Grid.Background>
            <ImageBrush ImageSource="{DynamicResource GlobalBackgroundSource}"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="40"/> <!-- Spacer for MacOS Traffic Lights Area -->
            <RowDefinition Height="80"/> <!-- Header & Back Button -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="1"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Gallery_Title]}"
                   FontSize="32"
                   FontWeight="Bold"
                   FontFamily="{DynamicResource DefaultFont}"
                   Foreground="{DynamicResource PastelText}"/>

        <!-- Back button (Aligned below traffic lights) -->
        <Button Grid.Row="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="18,0,0,0"
                Command="{Binding GoBackCommand}"
                Width="48" Height="48"
                Cursor="Hand"
                Background="{DynamicResource PastelPrimary}"
                BorderThickness="0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="24">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.3" Color="#C84747"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource PastelPrimaryHover}"/>
                            <Setter TargetName="Root" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.1" ScaleY="1.1" CenterX="24" CenterY="24"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95" CenterX="24" CenterY="24"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
            <Image Source="pack://application:,,,/Resources/Images/Icons/return-icon.png" 
                   Stretch="Uniform" Margin="14"
                   RenderOptions.BitmapScalingMode="HighQuality">
                <!-- Apply a white color filter to the icon if it's black/dark -->
                <Image.Effect>
                    <DropShadowEffect ShadowDepth="0" Color="White" BlurRadius="1" Opacity="1"/>
                </Image.Effect>
            </Image>
        </Button>

        <!-- Card grid -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBackground}"
                CornerRadius="{DynamicResource CardCornerRadius}"
                Margin="40,10,40,20"
                Padding="0,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.14" Color="#3D1C1C"/>
            </Border.Effect>

            <ScrollViewer Style="{DynamicResource PastelScrollViewer}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Cards}" HorizontalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Width="1200" Height="900"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                            <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                            <Setter Property="Panel.ZIndex" Value="{Binding ZIndex}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid MaxWidth="{Binding MaxWidth}" MaxHeight="{Binding MaxHeight}"
                                  Cursor="Hand"
                                  RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="HoverScale" ScaleX="1" ScaleY="1"/>
                                        <RotateTransform Angle="{Binding Rotation}"/>
                                    </TransformGroup>
                                </Grid.RenderTransform>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect ShadowDepth="5" BlurRadius="14"
                                                                  Color="#000000" Opacity="0.28"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Panel.ZIndex" Value="999"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect ShadowDepth="10" BlurRadius="26"
                                                                          Color="#000000" Opacity="0.4"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SelectCardCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Grid.InputBindings>

                                <Image Source="{Binding Current.ImagePath}"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>



        <!-- ═══════════════════════════════════════════════════════════════════
             Expansion overlay — visible only when a card is selected
             ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              Visibility="{Binding SelectedCard, Converter={StaticResource NullToCollapsedConverter}}">

            <!-- Dimmed background — click to close -->
            <Rectangle Fill="#CC000000"
                       MouseLeftButtonDown="OnOverlayBackgroundMouseDown"/>

            <!-- Centered card container -->
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="60">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">

                    <!-- Close (×) button — top-right above the card -->
                    <Button HorizontalAlignment="Right"
                        Margin="0,0,0,6"
                        Width="34" Height="34"
                        Content="×"
                        FontSize="20"
                        Foreground="White"
                        Background="#88000000"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding CloseCardCommand}"
                        Click="OnCloseExpandedButtonClicked">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root" Background="{TemplateBinding Background}"
                                    CornerRadius="17">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#CC000000"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                </Grid>

                <!-- Expanded card layout with arrows -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Content="&lt;" Command="{Binding SelectedCard.CycleBackCommand}"
                            Background="#66000000" Foreground="White" Width="44" Height="44" BorderThickness="0"
                            Margin="0,0,16,0" VerticalAlignment="Center" Cursor="Hand" FontSize="20" FontWeight="Bold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="22">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,2,2"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="#AA000000"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                <!-- Expanded card -->
                <Border Grid.Column="1"
                        CornerRadius="{DynamicResource CardCornerRadius}">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="0" BlurRadius="48"
                                          Color="#000000" Opacity="0.55"/>
                    </Border.Effect>
                    <Grid>
                        <!-- Card image — drag to move -->
                        <Border CornerRadius="{DynamicResource CardCornerRadius}" ClipToBounds="True">
                            <ScrollViewer x:Name="ExpandedScrollViewer" Style="{DynamicResource PastelScrollViewer}" 
                                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                          behaviors:ZoomPanBehavior.IsEnabled="True"
                                          behaviors:ZoomPanBehavior.ResetZoomTrigger="{Binding SelectedCard.Current}">
                                <Image Source="{Binding SelectedCard.Current.ImagePath}"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Cursor="SizeAll" />
                            </ScrollViewer>
                        </Border>

                        <!-- Variant label + hint strip at the bottom -->
                        <Border VerticalAlignment="Bottom"
                                Background="#80000000"
                                CornerRadius="0,0,18,18"
                                Padding="0,8,0,10">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedCard.Current.Label}"
                                           Foreground="White"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           FontFamily="{DynamicResource DefaultFont}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Gallery_Hint_Cycle]}"
                                           Foreground="#99FFFFFF"
                                           FontSize="11"
                                           FontFamily="{DynamicResource DefaultFont}"
                                           HorizontalAlignment="Center"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                
                    <Button Grid.Column="2" Content="&gt;" Command="{Binding SelectedCard.CycleCommand}"
                            Background="#66000000" Foreground="White" Width="44" Height="44" BorderThickness="0"
                            Margin="16,0,0,0" VerticalAlignment="Center" Cursor="Hand" FontSize="20" FontWeight="Bold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="22">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,2"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="#AA000000"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
