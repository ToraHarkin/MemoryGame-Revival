<Window x:Class="MemoryGame.Client.Views.Common.DialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:MemoryGame.Client.Localization"
        xmlns:converters="clr-namespace:MemoryGame.Client.Converters"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="200" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource CardBackground}"
            CornerRadius="{DynamicResource CardCornerRadius}"
            BorderBrush="{DynamicResource PastelBorder}"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.14" Color="#3D1C1C"/>
        </Border.Effect>

        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="{Binding Title}"
                       Style="{DynamicResource PastelLabel}"
                       FontSize="13"
                       Margin="0,0,0,10"
                       HorizontalAlignment="Left"/>

            <!-- Message -->
            <TextBlock Grid.Row="1"
                       Text="{Binding Message}"
                       Style="{DynamicResource PastelTextBlock}"
                       TextWrapping="Wrap"
                       FontSize="14"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"/>

            <!-- Buttons bar -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">

                <Button Content="OK"
                        Command="{Binding OKCommand}"
                        Visibility="{Binding OKVisibility}"
                        Style="{DynamicResource PastelButton}"
                        MinWidth="80" Height="36"
                        Margin="8,0,0,0"/>

                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Visibility="{Binding CancelVisibility}"
                        Style="{DynamicResource PastelButtonSecondary}"
                        MinWidth="80" Height="36"
                        Margin="8,0,0,0"/>

                <Button Content="Yes"
                        Command="{Binding YesCommand}"
                        Visibility="{Binding YesNoVisibility}"
                        Style="{DynamicResource PastelButton}"
                        MinWidth="80" Height="36"
                        Margin="8,0,0,0"/>

                <Button Content="No"
                        Command="{Binding NoCommand}"
                        Visibility="{Binding YesNoVisibility}"
                        Style="{DynamicResource PastelButtonSecondary}"
                        MinWidth="80" Height="36"
                        Margin="8,0,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
