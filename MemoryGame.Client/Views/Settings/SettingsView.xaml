<UserControl x:Class="MemoryGame.Client.Views.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MemoryGame.Client.Localization"
             xmlns:vm="clr-namespace:MemoryGame.Client.ViewModels.Settings"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720">

    <Grid>
        <!-- Background image -->
        <Grid.Background>
            <ImageBrush ImageSource="{DynamicResource GlobalBackgroundSource}"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <!-- Two-column layout: Logo (left) + Settings card (right) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Logo -->
            <Rectangle Grid.Column="0"
                       Width="280" Height="280"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="40,0,0,0">
                <Rectangle.Fill>
                    <ImageBrush ImageSource="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=LogoImage}"
                                Stretch="Uniform"/>
                </Rectangle.Fill>
            </Rectangle>

            <!-- RIGHT: Settings Card -->
            <Border Grid.Column="1"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource CardCornerRadius}"
                    Width="400"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="36,32"
                    Margin="0,0,40,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.14" Color="#3D1C1C"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Title -->
                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Settings_Label_Language]}"
                               Style="{DynamicResource PastelHeading}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,28"/>

                    <!-- ── Language ─────────────────────────────── -->
                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Settings_Label_Language]}"
                               Style="{DynamicResource PastelLabel}"
                               Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.Languages}}"
                              SelectedItem="{Binding SelectedLanguage}"
                              DisplayMemberPath="NativeName"
                              Style="{DynamicResource PastelComboBox}"
                              Margin="0,0,0,0"/>

                    <Rectangle Style="{DynamicResource SectionDivider}"/>

                    <!-- ── Theme ────────────────────────────────── -->
                    <TextBlock Text="Theme"
                               Style="{DynamicResource PastelLabel}"
                               Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.Themes}}"
                              SelectedItem="{Binding SelectedTheme}"
                              Style="{DynamicResource PastelComboBox}"
                              Margin="0,0,0,0"/>

                    <Rectangle Style="{DynamicResource SectionDivider}"/>

                    <!-- ── Music ────────────────────────────────── -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Settings_Label_Music]}"
                                   Style="{DynamicResource PastelLabel}"
                                   VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding IsMusicEnabled}"
                                  Style="{DynamicResource ToggleSwitch}"/>
                    </Grid>

                    <!-- Track selection (hidden when music is off) -->
                    <Grid Margin="0,0,0,12" Opacity="{Binding IsMusicEnabled, Converter={StaticResource InverseBoolConverter}}">
                        <TextBlock Text="Track"
                                   Style="{DynamicResource PastelLabel}"
                                   Margin="0,0,0,8"/>
                    </Grid>
                    <ComboBox ItemsSource="{Binding AvailableTracks}"
                              SelectedIndex="{Binding SelectedTrackIndex}"
                              Style="{DynamicResource PastelComboBox}"
                              Margin="0,0,0,12"
                              IsEnabled="{Binding IsMusicEnabled}">
                        <ComboBox.Opacity>
                            <Binding Path="IsMusicEnabled">
                                <Binding.Converter>
                                    <BooleanToVisibilityConverter/>
                                </Binding.Converter>
                            </Binding>
                        </ComboBox.Opacity>
                    </ComboBox>

                    <!-- Volume slider (hidden when music is off) -->
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Value="{Binding MusicVolume}"
                                Minimum="0" Maximum="1"
                                Style="{DynamicResource PastelSlider}"
                                VerticalAlignment="Center"
                                IsEnabled="{Binding IsMusicEnabled}">
                            <Slider.Opacity>
                                <Binding Path="IsMusicEnabled">
                                    <Binding.Converter>
                                        <BooleanToVisibilityConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </Slider.Opacity>
                        </Slider>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding MusicVolume, StringFormat={}{0:P0}}"
                                   Style="{DynamicResource PastelLabel}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   Opacity="{Binding IsMusicEnabled, Converter={StaticResource InverseBoolConverter}}"/>
                    </Grid>

                    <Rectangle Style="{DynamicResource SectionDivider}"/>

                    <!-- ── Display ──────────────────────────────── -->
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Settings_Label_Fullscreen]}"
                                   Style="{DynamicResource PastelLabel}"
                                   VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding IsFullscreen}"
                                  Style="{DynamicResource ToggleSwitch}"/>
                    </Grid>

                    <Rectangle Style="{DynamicResource SectionDivider}"/>

                    <!-- Back button -->
                    <Button HorizontalAlignment="Center"
                            Command="{Binding GoBackCommand}"
                            Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Back]}"
                            Style="{DynamicResource LinkButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
