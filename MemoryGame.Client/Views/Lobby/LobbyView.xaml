<UserControl x:Class="MemoryGame.Client.Views.Lobby.LobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MemoryGame.Client.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="{DynamicResource GlobalBackgroundSource}"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid VerticalAlignment="Center" HorizontalAlignment="Center"
              MaxWidth="900" Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ══ Header ══ -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[MainMenu_Button_Multiplayer]}"
                           Style="{DynamicResource PastelHeading}"
                           VerticalAlignment="Center"/>

                <!-- Game Code Badge -->
                <Border Grid.Column="1"
                        Background="{DynamicResource PastelPrimary}"
                        CornerRadius="12"
                        Padding="18,8"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Label_GameCode]}"
                                   FontFamily="{DynamicResource DefaultFont}"
                                   FontSize="15"
                                   Foreground="White"
                                   Opacity="0.85"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding GameCode}"
                                   FontFamily="{DynamicResource DefaultFont}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ Main Card ══ -->
            <Border Grid.Row="1"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource CardCornerRadius}"
                    Padding="28,20"
                    MinHeight="420">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.14" Color="#3D1C1C"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: Players -->
                    <Border Grid.Column="0"
                            Background="#06000000"
                            CornerRadius="14"
                            Padding="16,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Label_Players]}"
                                       Style="{DynamicResource PastelTextBlock}"
                                       FontWeight="SemiBold" FontSize="16"
                                       Foreground="{DynamicResource PastelPrimary}"
                                       Margin="0,0,0,10"/>

                            <!-- Empty state -->
                            <TextBlock Grid.Row="1"
                                       Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Lobby_Label_WaitingPlayers]}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="{DynamicResource DefaultFont}"
                                       FontSize="13"
                                       Foreground="{DynamicResource PastelTextLight}"
                                       Opacity="0.6">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Players.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Player list -->
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          MaxHeight="340">
                                <ItemsControl ItemsSource="{Binding Players}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#08000000"
                                                    CornerRadius="10"
                                                    Padding="14,10"
                                                    Margin="0,0,0,5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Avatar placeholder -->
                                                    <Border Grid.Column="0"
                                                            Width="38" Height="38"
                                                            CornerRadius="19"
                                                            Background="{DynamicResource PastelSecondary}"
                                                            Margin="0,0,12,0">
                                                        <TextBlock Text="👤"
                                                                   FontSize="16"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <!-- Username -->
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Username}"
                                                               Style="{DynamicResource PastelTextBlock}"
                                                               FontSize="15" FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>

                                                    <!-- Host crown -->
                                                    <TextBlock Grid.Column="2"
                                                               Text="👑"
                                                               FontSize="16"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding IsHost, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- RIGHT: Chat -->
                    <Border Grid.Column="2"
                            Background="#06000000"
                            CornerRadius="14"
                            Padding="16,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Lobby_Label_Chat]}"
                                       Style="{DynamicResource PastelTextBlock}"
                                       FontWeight="SemiBold" FontSize="16"
                                       Foreground="{DynamicResource PastelPrimary}"
                                       Margin="0,0,0,10"/>

                            <!-- Chat messages -->
                            <Border Grid.Row="1"
                                    Background="#04000000"
                                    CornerRadius="10"
                                    Padding="8"
                                    Margin="0,0,0,10">
                                <ScrollViewer x:Name="ChatScrollViewer"
                                              VerticalScrollBarVisibility="Auto"
                                              MaxHeight="280">
                                    <ItemsControl ItemsSource="{Binding ChatMessages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Style="{DynamicResource PastelTextBlock}"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,3"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <!-- Chat input -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding ChatMessage, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource PastelTextBox}">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter" Command="{Binding SendChatMessageCommand}"/>
                                    </TextBox.InputBindings>
                                </TextBox>

                                <Button Grid.Column="2"
                                        Style="{DynamicResource PastelButton}"
                                        Command="{Binding SendChatMessageCommand}"
                                        Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Send]}"
                                        Padding="16,6"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ══ Footer ══ -->
            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Leave -->
                <Button Grid.Column="0"
                        Command="{Binding LeaveCommand}"
                        Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Leave]}"
                        Style="{DynamicResource LinkButton}"/>

                <!-- Waiting indicator -->
                <TextBlock Grid.Column="1"
                           Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Lobby_Label_WaitingPlayers]}"
                           Style="{DynamicResource PastelTextBlock}"
                           FontSize="14"
                           Opacity="0.5"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
