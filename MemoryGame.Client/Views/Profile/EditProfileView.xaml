<UserControl x:Class="MemoryGame.Client.Views.Profile.EditProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MemoryGame.Client.Localization"
             xmlns:converters="clr-namespace:MemoryGame.Client.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720">

    <UserControl.Resources>
        <converters:ByteArrayToImageConverter x:Key="ByteArrayToImage"/>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="{DynamicResource GlobalBackgroundSource}"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="40"/> <!-- Spacer for MacOS Traffic Lights Area -->
            <RowDefinition Height="80"/> <!-- Header & Back Button -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        <!-- Back button (Gallery style) -->
        <Button Grid.Row="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="24,0,0,0"
                Command="{Binding GoBackCommand}"
                Width="48" Height="48"
                Cursor="Hand"
                Background="{DynamicResource PastelPrimary}"
                BorderThickness="0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="24">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.3" Color="#C84747"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource PastelPrimaryHover}"/>
                            <Setter TargetName="Root" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.1" ScaleY="1.1" CenterX="24" CenterY="24"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95" CenterX="24" CenterY="24"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
            <Image Source="pack://application:,,,/Resources/Images/Icons/return-icon.png" 
                   Stretch="Uniform" Margin="14"
                   RenderOptions.BitmapScalingMode="HighQuality">
                <Image.Effect>
                    <DropShadowEffect ShadowDepth="0" Color="White" BlurRadius="1" Opacity="1"/>
                </Image.Effect>
            </Image>
        </Button>

        <!-- Title -->
        <TextBlock Grid.Row="1"
                   Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Label_EditProfile]}"
                   Style="{DynamicResource PastelHeading}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Style="{DynamicResource PastelScrollViewer}">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="20,20,20,40">

                <!-- ══ Main Card ══ -->
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="{DynamicResource CardCornerRadius}"
                        Padding="64,48"
                        Margin="0,0,0,24" Width="857">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.14" Color="#3D1C1C"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ═══ LEFT COLUMN ═══ -->
                        <StackPanel Grid.Column="0">

                            <!-- ── Avatar Section ── -->
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Label_Avatar]}"
                                       Style="{DynamicResource PastelLabel}"
                                       Margin="0,0,0,12"/>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,12">
                                <!-- Avatar preview -->
                                <Border Width="90" Height="90"
                                        CornerRadius="45"
                                        BorderBrush="{DynamicResource PastelPrimary}"
                                        BorderThickness="2"
                                        Background="#10C84747"
                                        Margin="0,0,16,0">
                                    <Grid>
                                        <TextBlock Text="👤" FontSize="30"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding AvatarBytes, Converter={StaticResource NullToCollapsedConverter}, ConverterParameter=invert}"/>
                                        <Border CornerRadius="43" ClipToBounds="True">
                                            <Image Source="{Binding AvatarBytes, Converter={StaticResource ByteArrayToImage}}"
                                                   Stretch="UniformToFill"
                                                   Width="86" Height="86"
                                                   Visibility="{Binding AvatarBytes, Converter={StaticResource NullToCollapsedConverter}}"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Button VerticalAlignment="Center"
                                        Style="{DynamicResource PastelButtonSecondary}"
                                        Padding="16,6"
                                        Command="{Binding ChangeAvatarCommand}"
                                        Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Button_ChangeAvatar]}" Width="229"/>
                            </StackPanel>

                            <Rectangle Style="{DynamicResource SectionDivider}" Margin="0,24,0,24"/>

                            <!-- ── Personal Info ── -->
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Label_PersonalInfo]}"
                                       Style="{DynamicResource PastelLabel}"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Profile_Label_Name]}"
                                       Style="{DynamicResource PastelLabel}"
                                       Margin="0,0,0,6"/>
                            <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource PastelTextBox}"
                                     Margin="0,0,0,12"/>

                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Label_Username]}"
                                       Style="{DynamicResource PastelLabel}"
                                       Margin="0,0,0,6"/>
                            <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource PastelTextBox}"
                                     Margin="0,0,0,16"/>

                            <Button Style="{DynamicResource PastelButton}"
                                    Padding="20,8"
                                    HorizontalAlignment="Right"
                                    Command="{Binding UpdatePersonalInfoCommand}"
                                    Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Update]}" Width="150"/>

                            <Rectangle Style="{DynamicResource SectionDivider}" Margin="0,24,0,24"/>

                            <!-- ── Social Networks ── -->
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Profile_Label_SocialNetworks]}"
                                       Style="{DynamicResource PastelLabel}"
                                       Margin="0,0,0,12"/>

                            <ItemsControl ItemsSource="{Binding SocialNetworks}"
                                          Margin="0,0,0,12">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Account}"
                                                       Style="{DynamicResource PastelTextBlock}"
                                                       Foreground="{DynamicResource PastelPrimary}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <Button Grid.Column="1"
                                                    Content="✕"
                                                    Style="{DynamicResource PastelButtonDanger}"
                                                    Width="30" Height="28"
                                                    Padding="0"
                                                    FontSize="11"
                                                    Command="{Binding DataContext.RemoveSocialCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Add new social -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding NewSocialAccount, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource PastelTextBox}"
                                         Margin="0,0,8,0"/>

                                <Button Grid.Column="1"
                                        Content="+"
                                        Style="{DynamicResource PastelButton}"
                                        Width="40"
                                        Padding="0"
                                        FontSize="18"
                                        Command="{Binding AddSocialCommand}"/>
                            </Grid>
                        </StackPanel>

                        <!-- ═══ RIGHT COLUMN ═══ -->
                        <StackPanel Grid.Column="2">

                            <!-- ── Change Username ── -->
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Label_ChangeUsername]}"
                                       Style="{DynamicResource PastelLabel}"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Label_NewUsername]}"
                                       Style="{DynamicResource PastelLabel}"
                                       Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource PastelTextBox}"
                                     Margin="0,0,0,16"/>

                            <Button Style="{DynamicResource PastelButton}"
                                    Padding="20,8"
                                    HorizontalAlignment="Right"
                                    Command="{Binding UpdateUsernameCommand}"
                                    Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Update]}" Width="150"/>

                            <Rectangle Style="{DynamicResource SectionDivider}" Margin="0,24,0,24"/>

                            <!-- ── Change Password ── -->
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Button_UpdatePassword]}"
                                       Style="{DynamicResource PastelLabel}"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Label_ActualPassword]}"
                                       Style="{DynamicResource PastelLabel}"
                                       Margin="0,0,0,6"/>
                            <PasswordBox Style="{DynamicResource PastelPasswordBox}"
                                         Margin="0,0,0,12"
                                         PasswordChanged="CurrentPassword_PasswordChanged"/>

                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Label_NewPassword]}"
                                       Style="{DynamicResource PastelLabel}"
                                       Margin="0,0,0,6"/>
                            <PasswordBox Style="{DynamicResource PastelPasswordBox}"
                                         Margin="0,0,0,16"
                                         PasswordChanged="NewPassword_PasswordChanged"/>

                            <Button Style="{DynamicResource PastelButton}"
                                    Padding="20,8"
                                    HorizontalAlignment="Right"
                                    Command="{Binding UpdatePasswordCommand}"
                                    Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Update]}" Width="150"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
