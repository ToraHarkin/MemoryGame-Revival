<UserControl x:Class="MemoryGame.Client.Views.Profile.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MemoryGame.Client.Localization"
             xmlns:converters="clr-namespace:MemoryGame.Client.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720">

    <UserControl.Resources>
        <converters:ByteArrayToImageConverter x:Key="ByteArrayToImage"/>
    </UserControl.Resources>

    <Grid>
        <!-- Background -->
        <Grid.Background>
            <ImageBrush ImageSource="{DynamicResource GlobalBackgroundSource}"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <!-- Centered content -->
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center"
              MaxWidth="900" Width="661">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ══ Profile Card ══ -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource CardCornerRadius}"
                    Padding="50,48"
                    Margin="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.14" Color="#3D1C1C"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: Avatar + action buttons -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="0,0,50,0">
                        <!-- Avatar -->
                        <Border Width="140" Height="140"
                                CornerRadius="70"
                                BorderBrush="{DynamicResource PastelPrimary}"
                                BorderThickness="3"
                                HorizontalAlignment="Center"
                                Background="#10C84747">
                            <Grid>
                                <!-- Placeholder when no avatar -->
                                <TextBlock Text="👤"
                                           FontSize="48"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding AvatarBytes, Converter={StaticResource NullToCollapsedConverter}, ConverterParameter=invert}"/>
                                <!-- Avatar image -->
                                <Border CornerRadius="68" ClipToBounds="True">
                                    <Image Source="{Binding AvatarBytes, Converter={StaticResource ByteArrayToImage}}"
                                           Stretch="UniformToFill"
                                           Width="134" Height="134"
                                           Visibility="{Binding AvatarBytes, Converter={StaticResource NullToCollapsedConverter}}"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Edit Profile -->
                        <Button Margin="0,24,0,0"
                                HorizontalAlignment="Center"
                                Style="{DynamicResource PastelButtonSecondary}"
                                Height="36" Padding="20,0"
                                Command="{Binding GoToEditProfileCommand}"
                                Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Label_EditProfile]}"/>

                        <!-- Logout -->
                        <Button Margin="0,8,0,0"
                                HorizontalAlignment="Center"
                                Command="{Binding LogoutCommand}"
                                Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Logout]}"
                                Style="{DynamicResource LinkButton}"
                                Foreground="{DynamicResource PastelPrimary}"/>
                    </StackPanel>

                    <!-- RIGHT: User info -->
                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Username -->
                            <RowDefinition Height="Auto"/> <!-- Spacer -->
                            <RowDefinition Height="Auto"/> <!-- Name -->
                            <RowDefinition Height="Auto"/> <!-- Email -->
                            <RowDefinition Height="Auto"/> <!-- Reg Date -->
                            <RowDefinition Height="Auto"/> <!-- Socials -->
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Username (large heading) -->
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                   Text="{Binding Username}"
                                   Style="{DynamicResource PastelHeading}"
                                   FontSize="36"
                                   Margin="0,0,0,24"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- Name -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Profile_Label_Name]}"
                                   Style="{DynamicResource PastelLabel}"
                                   FontSize="14"
                                   Margin="0,0,16,12"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding FullName}"
                                   Style="{DynamicResource PastelTextBlock}"
                                   FontSize="16"
                                   Foreground="{DynamicResource PastelPrimary}"
                                   Margin="0,0,0,12"
                                   VerticalAlignment="Center"/>

                        <!-- Email -->
                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Label_Email]}"
                                   Style="{DynamicResource PastelLabel}"
                                   FontSize="14"
                                   Margin="0,0,16,12"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding Email}"
                                   Style="{DynamicResource PastelTextBlock}"
                                   FontSize="16"
                                   Foreground="{DynamicResource PastelPrimary}"
                                   Margin="0,0,0,12"
                                   VerticalAlignment="Center"/>

                        <!-- Registration Date -->
                        <TextBlock Grid.Row="4" Grid.Column="0"
                                   Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Profile_Label_RegistrationDate]}"
                                   Style="{DynamicResource PastelLabel}"
                                   FontSize="14"
                                   Margin="0,0,16,12"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="1"
                                   Text="{Binding RegistrationDate}"
                                   Style="{DynamicResource PastelTextBlock}"
                                   FontSize="16"
                                   Foreground="{DynamicResource PastelPrimary}"
                                   Margin="0,0,0,12"
                                   VerticalAlignment="Center"/>

                        <!-- Social Networks -->
                        <StackPanel Grid.Row="5" Grid.ColumnSpan="2"
                                    Margin="0,12,0,0"
                                    Visibility="{Binding HasSocialNetworks, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Profile_Label_SocialNetworks]}"
                                       Style="{DynamicResource PastelLabel}"
                                       FontSize="14"
                                       Margin="0,0,0,8"/>

                            <ItemsControl ItemsSource="{Binding SocialNetworks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="12,4,0,4">
                                            <TextBlock Text="•"
                                                       Style="{DynamicResource PastelTextBlock}"
                                                       Foreground="{DynamicResource PastelPrimary}"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Account}"
                                                       Style="{DynamicResource PastelTextBlock}"
                                                       Foreground="{DynamicResource PastelPrimary}"
                                                       FontSize="15"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ══ Bottom navigation buttons ══ -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,20">

                <Button Style="{DynamicResource PastelButton}"
                        Height="46" Padding="32,0"
                        Margin="0,0,16,0"
                        Command="{Binding GoToFriendsCommand}"
                        Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[MainMenu_Button_Friends]}"/>

                <Button Style="{DynamicResource PastelButtonSecondary}"
                        Height="46" Padding="32,0"
                        Margin="0,0,16,0"
                        Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[StatsHistory_Title]}"/>

                <Button HorizontalAlignment="Center"
                        Style="{DynamicResource LinkButton}"
                        Command="{Binding GoBackCommand}"
                        Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Back]}"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
