<UserControl x:Class="MemoryGame.Client.Views.Session.SetupProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MemoryGame.Client.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="{DynamicResource GlobalBackgroundSource}"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Rectangle Grid.Column="0"
                       Width="280" Height="280"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="40,0,0,0">
                <Rectangle.Fill>
                    <ImageBrush ImageSource="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=LogoImage}"
                                Stretch="Uniform"/>
                </Rectangle.Fill>
            </Rectangle>

            <Border Grid.Column="1"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource CardCornerRadius}"
                    Width="370"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="36,32"
                    Margin="0,0,40,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.14" Color="#3D1C1C"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[SetupProfile_Title]}"
                               Style="{DynamicResource PastelHeading}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[SetupProfile_Description]}"
                               Style="{DynamicResource PastelTextBlock}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               FontSize="13"
                               Margin="0,0,0,24"/>

                    <!-- Avatar preview + select button -->
                    <Border Width="120" Height="120"
                            CornerRadius="60"
                            BorderBrush="{DynamicResource PastelPrimary}"
                            BorderThickness="3"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,12"
                            Background="#10C84747"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding SelectAvatarCommand}"/>
                        </Border.InputBindings>

                        <Grid>
                            <!-- Placeholder icon when no avatar selected -->
                            <TextBlock Text="📷"
                                       FontSize="36"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding AvatarPreviewPath, Converter={StaticResource NullToCollapsedConverter}, ConverterParameter=invert}"/>

                            <!-- Selected avatar preview -->
                            <Border CornerRadius="58"
                                    ClipToBounds="True">
                                <Image Source="{Binding AvatarPreviewPath}"
                                       Stretch="UniformToFill"
                                       Visibility="{Binding AvatarPreviewPath, Converter={StaticResource NullToCollapsedConverter}}">
                                    <Image.Clip>
                                        <EllipseGeometry RadiusX="57" RadiusY="57" Center="57,57"/>
                                    </Image.Clip>
                                </Image>
                            </Border>
                        </Grid>
                    </Border>

                    <Button HorizontalAlignment="Center"
                            Margin="0,0,0,24"
                            Command="{Binding SelectAvatarCommand}"
                            Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[SetupProfile_SelectAvatar]}"
                            Style="{DynamicResource LinkButton}"/>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Style="{DynamicResource PastelErrorText}"
                               Margin="0,0,0,14"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>

                    <Button Height="46"
                            Margin="0,0,0,16"
                            Style="{DynamicResource PastelButton}"
                            Command="{Binding FinalizeCommand}"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                            Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Continue]}"/>

                    <Button HorizontalAlignment="Center"
                            Command="{Binding GoBackCommand}"
                            Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Back]}"
                            Style="{DynamicResource LinkButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
