<UserControl x:Class="MemoryGame.Client.Views.Session.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MemoryGame.Client.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="{DynamicResource GlobalBackgroundSource}"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Rectangle Grid.Column="0"
                       Width="280" Height="280"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="40,0,0,0">
                <Rectangle.Fill>
                    <ImageBrush ImageSource="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=LogoImage}"
                                Stretch="Uniform"/>
                </Rectangle.Fill>
            </Rectangle>

            <Border Grid.Column="1"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource CardCornerRadius}"
                    Width="370"
                    MaxHeight="600"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="36,32"
                    Margin="0,0,40,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.14" Color="#3D1C1C"/>
                </Border.Effect>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Register_Title]}"
                                   Style="{DynamicResource PastelHeading}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,24"/>

                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Label_Username]}"
                                   Style="{DynamicResource PastelLabel}"
                                   Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource PastelTextBox}"
                                 Margin="0,0,0,14"/>

                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Label_Email]}"
                                   Style="{DynamicResource PastelLabel}"
                                   Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource PastelTextBox}"
                                 Margin="0,0,0,14"/>

                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Label_Password]}"
                                   Style="{DynamicResource PastelLabel}"
                                   Margin="0,0,0,6"/>
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{DynamicResource PastelPasswordBox}"
                                     Margin="0,0,0,14"/>

                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Label_ConfirmPassword]}"
                                   Style="{DynamicResource PastelLabel}"
                                   Margin="0,0,0,6"/>
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     Style="{DynamicResource PastelPasswordBox}"
                                     Margin="0,0,0,18"/>

                        <TextBlock Text="{Binding ErrorMessage}"
                                   Style="{DynamicResource PastelErrorText}"
                                   Margin="0,0,0,14"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>

                        <Button Height="46"
                                Margin="0,0,0,16"
                                Style="{DynamicResource PastelButton}"
                                Command="{Binding RegisterCommand}"
                                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                                Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Register]}"/>

                        <Button HorizontalAlignment="Center"
                                Command="{Binding GoBackCommand}"
                                Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Back]}"
                                Style="{DynamicResource LinkButton}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
