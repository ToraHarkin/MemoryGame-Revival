<UserControl x:Class="MemoryGame.Client.Views.Session.VerifyEmailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MemoryGame.Client.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="{DynamicResource GlobalBackgroundSource}"
                        Stretch="UniformToFill"/>
        </Grid.Background>
        <Grid>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Rectangle Grid.Column="0"
                       Width="280" Height="280"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="40,0,0,0">
                <Rectangle.Fill>
                    <ImageBrush ImageSource="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=LogoImage}"
                                Stretch="Uniform"/>
                </Rectangle.Fill>
            </Rectangle>

            <Border Grid.Column="1"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource CardCornerRadius}"
                    Width="360"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="36,32"
                    Margin="0,0,40,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.14" Color="#3D1C1C"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[VerifyEmail_Title]}"
                               Style="{DynamicResource PastelHeading}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14"/>

                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[VerifyEmail_Description]}"
                               Style="{DynamicResource PastelTextBlock}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               FontSize="13"
                               Margin="0,0,0,22"/>

                    <TextBox Text="{Binding Pin, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="6"
                             Style="{DynamicResource PastelTextBox}"
                             FontSize="32" FontWeight="Bold"
                             FontFamily="Courier New"
                             TextAlignment="Center"
                             Height="56"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="{Binding PinResentMessage}"
                               Style="{DynamicResource PastelTextBlock}"
                               FontSize="12"
                               Foreground="{DynamicResource PastelSuccess}"
                               TextAlignment="Center"
                               Margin="0,0,0,12"
                               Visibility="{Binding PinResentMessage, Converter={StaticResource NullToCollapsedConverter}}"/>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Style="{DynamicResource PastelErrorText}"
                               Margin="0,0,0,14"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>

                    <Button Height="46"
                            Margin="0,0,0,14"
                            Style="{DynamicResource PastelButton}"
                            Command="{Binding VerifyCommand}"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                            Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Verify]}"/>

                    <Button Margin="0,0,0,10"
                            HorizontalAlignment="Center"
                            Command="{Binding ResendPinCommand}"
                            Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_ResendPin]}"
                            Style="{DynamicResource LinkButton}"/>

                    <Button HorizontalAlignment="Center"
                            Command="{Binding GoBackCommand}"
                            Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Back]}"
                            Style="{DynamicResource LinkButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
