<UserControl x:Class="MemoryGame.Client.Views.MainMenu.MoreMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MemoryGame.Client.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720">

    <UserControl.Resources>
        <!-- Section card button style -->
        <Style x:Key="SectionCard" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="{DynamicResource DefaultFont}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{DynamicResource CardCornerRadius}"
                                Padding="28,32"
                                Width="200"
                                Height="180">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.12" Color="#3D1C1C"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource PastelSecondary}"/>
                                <Setter TargetName="Root" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="28" ShadowDepth="5" Opacity="0.22" Color="#C84747"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource PastelAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="{DynamicResource GlobalBackgroundSource}"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[MainMenu_Button_More]}"
                       Style="{DynamicResource PastelHeading}"
                       HorizontalAlignment="Center"/>

            <!-- Section cards -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <!-- ── Gallery ── -->
                <Button Style="{StaticResource SectionCard}"
                        Margin="0,0,20,0"
                        Command="{Binding GoToGalleryCommand}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🃏"
                                   FontSize="44"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Gallery_Title]}"
                                   Style="{DynamicResource PastelTextBlock}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource PastelText}"/>
                    </StackPanel>
                </Button>

                <!-- ── Profile ── -->
                <Button Style="{StaticResource SectionCard}"
                        Margin="0,0,20,0"
                        Command="{Binding GoToProfileCommand}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="👤"
                                   FontSize="44"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[MainMenu_Button_Profile]}"
                                   Style="{DynamicResource PastelTextBlock}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource PastelText}"/>
                    </StackPanel>
                </Button>

                <!-- ── Friends ── -->
                <Button Style="{StaticResource SectionCard}"
                        Command="{Binding GoToFriendsCommand}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🤝"
                                   FontSize="44"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[MainMenu_Button_Friends]}"
                                   Style="{DynamicResource PastelTextBlock}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource PastelText}"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Back -->
            <Button Grid.Row="4"
                    HorizontalAlignment="Center"
                    Command="{Binding GoBackCommand}"
                    Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Back]}"
                    Style="{DynamicResource LinkButton}"/>
        </Grid>
    </Grid>
</UserControl>
