<UserControl x:Class="MemoryGame.Client.Views.Social.FriendsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MemoryGame.Client.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="{DynamicResource GlobalBackgroundSource}"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid VerticalAlignment="Center" HorizontalAlignment="Center"
              MaxWidth="900" Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Friends_Title]}"
                       Style="{DynamicResource PastelHeading}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

            <!-- ══ Main Card with Tabs ══ -->
            <Border Grid.Row="1"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource CardCornerRadius}"
                    Padding="28,20"
                    MinHeight="420">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.14" Color="#3D1C1C"/>
                </Border.Effect>

                <TabControl Style="{DynamicResource PastelTabControl}">

                    <!-- ═══ TAB 1: My Friends ═══ -->
                    <TabItem Header="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Friends_Label_MyFriends]}">
                        <Grid Margin="0,12,0,0">
                            <!-- Empty state -->
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Friends_Label_NoFriends]}"
                                       Style="{DynamicResource PastelTextBlock}"
                                       Foreground="{DynamicResource PastelTextLight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Visibility="{Binding HasFriends, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"/>

                            <!-- Friends list -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Style="{DynamicResource PastelScrollViewer}"
                                          MaxHeight="340"
                                          Visibility="{Binding HasFriends, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ItemsControl ItemsSource="{Binding Friends}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#08000000"
                                                    CornerRadius="12"
                                                    Padding="16,12"
                                                    Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Avatar placeholder -->
                                                    <Border Grid.Column="0"
                                                            Width="44" Height="44"
                                                            CornerRadius="22"
                                                            Background="{DynamicResource PastelSecondary}"
                                                            Margin="0,0,14,0">
                                                        <TextBlock Text="👤"
                                                                   FontSize="18"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <!-- Username + friends since -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Username}"
                                                                   Style="{DynamicResource PastelTextBlock}"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold"/>
                                                        <TextBlock Style="{DynamicResource PastelLabel}"
                                                                   FontSize="11">
                                                            <TextBlock.Text>
                                                                <Binding Path="FriendsSince"
                                                                         StringFormat="{}{0:MMM dd, yyyy}"/>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <!-- Remove button -->
                                                    <Button Grid.Column="3"
                                                            Style="{DynamicResource PastelButtonDanger}"
                                                            Padding="12,4"
                                                            VerticalAlignment="Center"
                                                            Command="{Binding DataContext.RemoveFriendCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="✕" FontSize="12"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- ═══ TAB 2: Requests ═══ -->
                    <TabItem Header="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Friends_Label_PendingRequests]}">
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- LEFT: Add Friend form -->
                            <Border Grid.Column="0"
                                    Background="#06000000"
                                    CornerRadius="14"
                                    Padding="20,18">
                                <StackPanel>
                                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Friends_Label_AddFriend]}"
                                               Style="{DynamicResource PastelTextBlock}"
                                               FontWeight="SemiBold"
                                               FontSize="16"
                                               Margin="0,0,0,12"/>

                                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Friends_Label_EnterUsername]}"
                                               Style="{DynamicResource PastelLabel}"
                                               Margin="0,0,0,6"/>

                                    <TextBox Text="{Binding SearchUsername, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource PastelTextBox}"
                                             Margin="0,0,0,12"/>

                                    <Button Style="{DynamicResource PastelButton}"
                                            Padding="20,8"
                                            HorizontalAlignment="Right"
                                            Command="{Binding SendRequestCommand}"
                                            Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Friends_Button_SendRequest]}"/>
                                </StackPanel>
                            </Border>

                            <!-- RIGHT: Pending Requests list -->
                            <Border Grid.Column="2"
                                    Background="#06000000"
                                    CornerRadius="14"
                                    Padding="20,18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Friends_Label_PendingRequests]}"
                                               Style="{DynamicResource PastelTextBlock}"
                                               FontWeight="SemiBold"
                                               FontSize="16"
                                               Margin="0,0,0,12"/>

                                    <!-- Empty state -->
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Friends_Label_NoRequests]}"
                                               Style="{DynamicResource PastelTextBlock}"
                                               Foreground="{DynamicResource PastelTextLight}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               Visibility="{Binding HasRequests, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"/>

                                    <!-- Requests list -->
                                    <ScrollViewer Grid.Row="1"
                                                  VerticalScrollBarVisibility="Auto"
                                                  Style="{DynamicResource PastelScrollViewer}"
                                                  MaxHeight="280"
                                                  Visibility="{Binding HasRequests, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl ItemsSource="{Binding PendingRequests}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#08000000"
                                                            CornerRadius="10"
                                                            Padding="12,10"
                                                            Margin="0,0,0,6">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Avatar placeholder -->
                                                            <Border Grid.Column="0"
                                                                    Width="40" Height="40"
                                                                    CornerRadius="20"
                                                                    Background="{DynamicResource PastelSecondary}"
                                                                    Margin="0,0,10,0">
                                                                <TextBlock Text="👤"
                                                                           FontSize="16"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                            </Border>

                                                            <!-- Sender username -->
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding SenderUsername}"
                                                                       Style="{DynamicResource PastelTextBlock}"
                                                                       FontSize="15"
                                                                       FontWeight="SemiBold"
                                                                       VerticalAlignment="Center"/>

                                                            <!-- Accept / Reject -->
                                                            <StackPanel Grid.Column="2"
                                                                        Orientation="Horizontal"
                                                                        VerticalAlignment="Center">
                                                                <Button Style="{DynamicResource PastelButtonSuccess}"
                                                                        Height="30" Padding="10,0"
                                                                        FontSize="12"
                                                                        Margin="0,0,6,0"
                                                                        Command="{Binding DataContext.AcceptRequestCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding RequestId}"
                                                                        Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Accept]}"/>

                                                                <Button Style="{DynamicResource PastelButtonDanger}"
                                                                        Height="30" Padding="10,0"
                                                                        FontSize="12"
                                                                        Command="{Binding DataContext.RejectRequestCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding RequestId}"
                                                                        Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Reject]}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <!-- Back button -->
            <Button Grid.Row="2"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0"
                    Command="{Binding GoBackCommand}"
                    Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Back]}"
                    Style="{DynamicResource LinkButton}"/>
        </Grid>
    </Grid>
</UserControl>
